# Notion 견적서 뷰어 — 환경 변수 템플릿
#
# 사용법:
#   cp .env.local.example .env.local
#   그리고 아래 키들의 값을 채운다. .env.local은 .gitignore에 등록되어 있어 커밋되지 않는다.
#
# 보안:
#   - 모든 값은 서버 전용이다. NEXT_PUBLIC_ 접두사를 절대 붙이지 말 것
#     (붙이는 순간 클라이언트 번들에 포함된다).
#   - 토큰 값은 어디에도 로깅하지 말 것. PRD §7 / lib/logger.ts 참고.

# Notion Internal Integration secret. https://www.notion.so/my-integrations 에서 발급.
NOTION_TOKEN=

# 견적서 데이터베이스의 page id (32자 hyphen 포함). DB URL의 마지막 segment.
NOTION_DATABASE_ID=

# (스크립트 전용) Notion API v2 data source id. scripts/*.mjs가 dataSources.query()를 호출할 때 사용.
# 일반 dev/build에는 불필요하나, seed-tokens / notion-migrate 등을 돌리려면 필요.
NOTION_DATA_SOURCE_ID=

# 로깅 레벨. debug | info | warn | error (기본: info)
LOG_LEVEL=info
